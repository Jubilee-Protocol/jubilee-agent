{
  "name": "@jubilee/core",
  "version": "1.0.0",
  "description": "Jubilee Core - A Triune AI Agent (Mind, Prophet, Will) for research, coding, and operations.",
  "type": "module",
  "main": "dist/core.js",
  "types": "dist/core.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "jubilee": "./src/index.tsx",
    "jubilee-sprint": "./src/sprint-runner.ts"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "sprint": "bun run src/sprint-runner.ts",
    "dev": "bun --watch run src/index.tsx",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "postinstall": "playwright install chromium",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@coinbase/agentkit": "^0.10.4",
    "@coinbase/agentkit-langchain": "^0.3.0",
    "@hono/node-server": "^1.19.11",
    "@lancedb/lancedb": "^0.24.1",
    "@lancedb/lancedb-darwin-arm64": "^0.24.1",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.35",
    "@langchain/exa": "^1.0.1",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.3.0",
    "@langchain/tavily": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "exa-js": "^2.8.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.8",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "langsmith": "^0.4.12",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "uuid": "^13.0.0",
    "viem": "^2.47.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/bun": "latest",
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "babel-jest": "^30.3.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}